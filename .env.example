# On Call Helper - Environment Variables
# Copy this file to .env and fill in the values

# ═══════════════ App ═══════════════
DEBUG=true
LOG_LEVEL=INFO

# ═══════════════ AI - Anthropic Direct (default) ═══════════════
ANTHROPIC_API_KEY=sk-ant-...
TRIAGE_MODEL=claude-sonnet-4-20250514
FIXER_MODEL=claude-sonnet-4-20250514

# ═══════════════ AI - Vertex AI (alternative) ═══════════════
# Set USE_VERTEX=true to use Vertex AI instead of direct Anthropic API
# Requires GCP credentials (gcloud auth application-default login or GOOGLE_APPLICATION_CREDENTIALS)
USE_VERTEX=false
VERTEX_PROJECT_ID=anthropic-vertex
VERTEX_REGION=us-east5
VERTEX_TRIAGE_MODEL=claude-sonnet-4-5@20250929
VERTEX_FIXER_MODEL=claude-sonnet-4-5@20250929

# ═══════════════ GCP ═══════════════
GCP_PROJECT_ID=your-project-id
GCP_CREDENTIALS_PATH=./credentials.json
GCP_LOG_FILTER=severity>=ERROR

# ═══════════════ GitHub ═══════════════
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/nucleus
GITHUB_BASE_BRANCH=main

# ═══════════════ PagerDuty ═══════════════
PAGERDUTY_ROUTING_KEY=your-routing-key

# ═══════════════ CodeRabbit ═══════════════
CODERABBIT_MAX_RETRIES=3

# ═══════════════ Sandbox ═══════════════
SANDBOX_TIMEOUT_MINUTES=15

# ═══════════════ Repository Paths ═══════════════
NUCLEUS_REPO_PATH=/Users/sri/nucleus
ONCALL_REPO_PATH=/Users/sri/oncall

# ═══════════════ Production Monitoring ═══════════════
VERIFICATION_DURATION_HOURS=2
VERIFICATION_CHECK_INTERVAL_MINUTES=5

# ═══════════════ Storage ═══════════════
# Options: 'memory' (default, lost on restart) or 'firestore' (persistent)
STORAGE_BACKEND=memory

# ═══════════════ Dashboard ═══════════════
DASHBOARD_URL=http://localhost:3000
